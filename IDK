<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SLC — Master Architecture v5</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0d0f14;--bg2:#13161e;--bg3:#1a1e2a;
  --b:rgba(255,255,255,0.07);--bb:rgba(255,255,255,0.13);
  --teal:#1dd9a0;--td2:rgba(29,217,160,0.1);--tg:rgba(29,217,160,0.15);
  --amber:#f59e0b;--ad:rgba(245,158,11,0.1);--ag:rgba(245,158,11,0.15);
  --vio:#8b5cf6;--vd:rgba(139,92,246,0.12);--vg:rgba(139,92,246,0.18);
  --rose:#f43f5e;--rd:rgba(244,63,94,0.12);--rg:rgba(244,63,94,0.18);
  --orange:#fb923c;--od:rgba(251,146,60,0.12);
  --sky:#38bdf8;--skd:rgba(56,189,248,0.1);--skg:rgba(56,189,248,0.15);
  --green:#22c55e;--grd:rgba(34,197,94,0.1);
  --text:#e8eaf0;--tm:rgba(232,234,240,0.5);--td:rgba(232,234,240,0.24);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;padding:28px 18px 80px;line-height:1.5;}

/* TABS */
.tabs{display:flex;gap:3px;margin-bottom:22px;background:var(--bg2);padding:4px;border-radius:11px;border:1px solid var(--b);flex-wrap:wrap;}
.tab{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.05em;padding:5px 11px;border-radius:7px;cursor:pointer;color:var(--td);border:none;background:transparent;transition:all 0.12s;white-space:nowrap;}
.tab.on{background:var(--bg3);color:var(--text);border:1px solid var(--bb);}
.tab:hover:not(.on){color:var(--tm);}
.view{display:none;}.view.on{display:block;}

/* HEADER */
.hdr{margin-bottom:24px;}
.ey{font-family:'DM Mono',monospace;font-size:9.5px;letter-spacing:0.12em;color:var(--teal);text-transform:uppercase;margin-bottom:7px;}
h1{font-family:'Syne',sans-serif;font-weight:800;font-size:23px;letter-spacing:-0.02em;line-height:1.1;color:#fff;margin-bottom:5px;}
.sub{color:var(--tm);font-size:11.5px;font-weight:300;max-width:620px;line-height:1.6;}

/* GATE */
.gate-w{display:flex;justify-content:center;}
.gate{background:var(--bg2);border:1px solid var(--bb);border-radius:12px;padding:11px 30px;text-align:center;display:inline-flex;flex-direction:column;align-items:center;gap:3px;min-width:300px;position:relative;}
.gate::before{content:'';position:absolute;inset:-1px;border-radius:13px;background:linear-gradient(120deg,rgba(29,217,160,0.16),transparent 50%);z-index:-1;}
.gl{font-family:'DM Mono',monospace;font-size:8.5px;letter-spacing:0.12em;text-transform:uppercase;color:var(--teal);}
.gt{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;color:#fff;}
.gs{font-size:10.5px;color:var(--tm);}
.fork{display:flex;justify-content:center;padding:2px 0 12px;}

/* COLUMNS */
.cols{display:grid;grid-template-columns:1fr 1fr;gap:12px;}

/* STAGE */
.stage{border-radius:13px;border:1px solid var(--b);background:var(--bg2);overflow:hidden;transition:border-color 0.18s;}
.s1c:hover{border-color:rgba(29,217,160,0.14);}
.s2c:hover{border-color:rgba(245,158,11,0.14);}
.sh{padding:12px 14px 10px;border-bottom:1px solid var(--b);display:flex;align-items:flex-start;gap:9px;}
.sn2{font-family:'Syne',sans-serif;font-weight:800;font-size:20px;line-height:1;margin-top:2px;flex-shrink:0;}
.s1c .sn2{color:var(--teal);}
.s2c .sn2{color:var(--amber);}
.snm{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;}
.stg{font-size:10px;color:var(--tm);margin-top:1px;}
.su{font-family:'DM Mono',monospace;font-size:8px;letter-spacing:0.05em;margin-top:4px;padding:2px 5px;border-radius:4px;display:inline-block;}
.s1c .su{background:var(--td2);color:var(--teal);}
.s2c .su{background:var(--ad);color:var(--amber);}

/* SECTIONS */
.sg{padding:8px 8px 2px;}
.sl{font-family:'DM Mono',monospace;font-size:8px;letter-spacing:0.1em;text-transform:uppercase;color:var(--td);margin-bottom:6px;display:flex;align-items:center;gap:5px;}
.sl::after{content:'';flex:1;height:1px;background:var(--b);}
.sdv{display:flex;align-items:center;gap:5px;padding:2px 8px 0;}
.sdvl{flex:1;height:1px;background:var(--b);}
.sdvt{font-family:'DM Mono',monospace;font-size:7px;color:var(--td);letter-spacing:0.06em;white-space:nowrap;}

/* MODULE GRID + CARD */
.mg{display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-bottom:5px;}
.mod{background:var(--bg3);border:1px solid var(--b);border-radius:7px;padding:7px 8px;cursor:pointer;transition:all 0.12s;position:relative;overflow:hidden;}
.mod::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;opacity:0;transition:opacity 0.13s;}
.mod:hover{border-color:var(--bb);transform:translateY(-1px);}
.mod:hover::before{opacity:1;}
.s1c .mod::before{background:var(--teal);}
.s1c .mod:hover{box-shadow:0 3px 10px var(--tg);}
.s2c .mod::before{background:var(--amber);}
.s2c .mod:hover{box-shadow:0 3px 10px var(--ag);}
.v-mod::before{background:var(--vio)!important;}
.v-mod:hover{box-shadow:0 3px 10px var(--vg)!important;}
.sim-fixed{border-color:rgba(29,217,160,0.18)!important;}
.sim-fixed::after{content:'✓ sim';position:absolute;top:4px;right:5px;font-family:'DM Mono',monospace;font-size:6.5px;color:var(--teal);opacity:0.6;}
.sync-updated{border-color:rgba(139,92,246,0.2)!important;}
.sync-updated::after{content:'↑ sync';position:absolute;top:4px;right:5px;font-family:'DM Mono',monospace;font-size:6.5px;color:var(--vio);opacity:0.6;}

.mt2{font-family:'Syne',sans-serif;font-weight:600;font-size:10.5px;color:#fff;line-height:1.3;margin-bottom:2px;}
.md2{font-size:9px;color:var(--td);line-height:1.4;}
.mk3{display:inline-block;margin-top:3px;font-family:'DM Mono',monospace;font-size:7px;letter-spacing:0.04em;padding:1px 4px;border-radius:3px;}
.s1c .mk3{background:var(--td2);color:var(--teal);}
.s2c .mk3{background:var(--ad);color:var(--amber);}
.vk{background:var(--vd)!important;color:var(--vio)!important;}
.nbg{display:inline-block;margin-left:2px;font-family:'DM Mono',monospace;font-size:6.5px;padding:1px 3px;border-radius:2px;background:rgba(139,92,246,0.2);color:var(--vio);vertical-align:middle;}

/* UNLOCK + PENDING */
.unlk{background:linear-gradient(90deg,rgba(245,158,11,0.05),transparent);border:1px solid rgba(245,158,11,0.09);border-radius:6px;padding:6px 9px;margin:0 8px 8px;font-size:9.5px;color:var(--tm);display:flex;align-items:flex-start;gap:5px;line-height:1.5;}
.ui{color:var(--amber);font-size:9.5px;flex-shrink:0;margin-top:1px;}
.pm{background:var(--bg3);border:1px dashed rgba(255,255,255,0.06);border-radius:7px;padding:7px 8px;cursor:pointer;opacity:0.42;transition:opacity 0.12s;}
.pm:hover{opacity:0.65;}
.pt{display:inline-block;margin-top:3px;font-family:'DM Mono',monospace;font-size:7px;padding:1px 4px;border-radius:3px;background:rgba(255,255,255,0.05);color:var(--td);}

/* STATS */
.stats{display:flex;gap:5px;margin-top:16px;flex-wrap:wrap;}
.sc{flex:1;min-width:85px;background:var(--bg2);border:1px solid var(--b);border-radius:9px;padding:9px 12px;}
.snum{font-family:'Syne',sans-serif;font-weight:800;font-size:19px;line-height:1;margin-bottom:2px;}
.slb{font-size:9.5px;color:var(--tm);}

/* ══ MARKETING / COMPETITOR / STRESS shared styles ══ */
.section-intro{border-radius:11px;padding:13px 16px;margin-bottom:14px;}
.section-intro h2{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;color:#fff;margin-bottom:4px;}
.section-intro p{font-size:11px;color:var(--tm);line-height:1.6;}
.si-vio{background:linear-gradient(135deg,var(--vd),transparent);border:1px solid rgba(139,92,246,0.2);}
.si-rose{background:linear-gradient(135deg,var(--rd),transparent);border:1px solid rgba(244,63,94,0.2);}
.si-sky{background:linear-gradient(135deg,var(--skd),transparent);border:1px solid rgba(56,189,248,0.2);}

.two-col{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
.card{background:var(--bg2);border-radius:10px;padding:12px 14px;border:1px solid var(--b);}
.card-title{font-family:'Syne',sans-serif;font-weight:700;font-size:12px;color:#fff;margin-bottom:4px;}
.card-body{font-size:10.5px;color:var(--tm);line-height:1.6;}
.card-list{list-style:none;display:flex;flex-direction:column;gap:3px;margin-top:5px;}
.card-list li{font-size:10px;color:var(--tm);padding-left:11px;position:relative;}
.card-list li::before{content:'→';position:absolute;left:0;color:var(--td);font-size:9px;}

/* DOMAIN GRID (marketing) */
.dom-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
.dom{background:var(--bg2);border:1px solid rgba(139,92,246,0.16);border-radius:10px;overflow:hidden;}
.dom-h{padding:9px 12px;border-bottom:1px solid var(--b);background:rgba(139,92,246,0.04);}
.dom-ht{font-family:'Syne',sans-serif;font-weight:700;font-size:11.5px;color:var(--vio);}
.dom-hs{font-size:9.5px;color:var(--td);margin-top:1px;}
.dom-b{padding:8px;}
.dm{background:var(--bg3);border:1px solid var(--b);border-radius:6px;padding:7px 9px;margin-bottom:4px;cursor:pointer;transition:all 0.11s;}
.dm:last-child{margin-bottom:0;}
.dm:hover{border-color:rgba(139,92,246,0.28);box-shadow:0 3px 9px var(--vg);}
.dm-t{font-family:'Syne',sans-serif;font-weight:600;font-size:10.5px;color:#fff;margin-bottom:2px;}
.dm-d{font-size:9px;color:var(--td);line-height:1.4;}
.dm-k{display:inline-block;margin-top:3px;font-family:'DM Mono',monospace;font-size:7px;padding:1px 4px;border-radius:3px;background:var(--vd);color:var(--vio);}

/* COMPETITOR CARDS */
.comp-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.cc{background:var(--bg2);border-radius:10px;padding:12px 14px;border:1px solid var(--b);border-left:3px solid transparent;}
.cc.full{border-left-color:var(--teal);}
.cc.added{border-left-color:var(--vio);}
.cc.structural{border-left-color:rgba(255,255,255,0.2);}
.cc.partial{border-left-color:var(--amber);}
.cs{font-family:'DM Mono',monospace;font-size:8px;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:4px;display:flex;align-items:center;gap:4px;}
.dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.dg{background:var(--teal);}.dv{background:var(--vio);}.dw{background:rgba(255,255,255,0.3);}.da{background:var(--amber);}
.ct{font-family:'Syne',sans-serif;font-weight:700;font-size:12.5px;color:#fff;margin-bottom:4px;}
.cb{font-size:10.5px;color:var(--tm);line-height:1.55;margin-bottom:5px;}
.ctags{display:flex;flex-wrap:wrap;gap:3px;}
.ctag{font-family:'DM Mono',monospace;font-size:7.5px;padding:1px 4px;border-radius:3px;}
.ctag-g{background:var(--td2);color:var(--teal);}
.ctag-v{background:var(--vd);color:var(--vio);}
.ctag-a{background:var(--ad);color:var(--amber);}
.ctag-n{background:rgba(255,255,255,0.05);color:var(--td);}
.cnote{margin-top:5px;padding-top:5px;border-top:1px solid var(--b);font-size:9.5px;color:var(--td);font-style:italic;line-height:1.5;}

/* STRESS TEST */
.persona-bar{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin-bottom:14px;}
.pb{background:var(--bg2);border:1px solid var(--b);border-radius:8px;padding:9px 11px;}
.pb-l{font-family:'DM Mono',monospace;font-size:8px;letter-spacing:0.08em;text-transform:uppercase;color:var(--td);margin-bottom:3px;}
.pb-v{font-size:10.5px;color:var(--tm);line-height:1.5;}
.pb-v strong{color:#fff;font-weight:500;}
.stress-table{width:100%;border-collapse:collapse;}
.stress-table th{font-family:'DM Mono',monospace;font-size:8px;letter-spacing:0.08em;text-transform:uppercase;color:var(--td);padding:7px 9px;text-align:left;border-bottom:1px solid var(--b);}
.stress-table td{font-size:10.5px;color:var(--tm);padding:8px 9px;border-bottom:1px solid var(--b);vertical-align:top;line-height:1.5;}
.stress-table tr:last-child td{border-bottom:none;}
.stress-table tr:hover td{background:rgba(255,255,255,0.012);}
.sev{display:inline-block;font-family:'DM Mono',monospace;font-size:7.5px;padding:2px 5px;border-radius:3px;white-space:nowrap;}
.sev-c{background:var(--rd);color:var(--rose);}
.sev-h{background:var(--od);color:var(--orange);}
.sev-m{background:var(--ad);color:var(--amber);}
.sev-l{background:var(--td2);color:var(--teal);}
.sev-p{background:var(--td2);color:var(--teal);}
.scen-pill{font-family:'DM Mono',monospace;font-size:7.5px;padding:1px 5px;border-radius:3px;display:inline-block;margin-right:3px;}
.sp-s1{background:var(--td2);color:var(--teal);}
.sp-s2{background:var(--od);color:var(--orange);}
.sp-s3{background:var(--rd);color:var(--rose);}
.sp-d1{background:var(--vd);color:var(--vio);}

/* ══ SUGGESTED MODULES ══ */
.suggest-intro{background:linear-gradient(135deg,rgba(56,189,248,0.08),rgba(56,189,248,0.02));border:1px solid rgba(56,189,248,0.2);border-radius:11px;padding:14px 18px;margin-bottom:18px;}
.suggest-intro h2{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;color:#fff;margin-bottom:4px;}
.suggest-intro p{font-size:11px;color:var(--tm);line-height:1.6;}
.tier-label{font-family:'DM Mono',monospace;font-size:8.5px;letter-spacing:0.1em;text-transform:uppercase;margin:18px 0 10px;}
.suggest-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:4px;}
.sm-card{background:var(--bg2);border-radius:10px;padding:13px 15px;border:1px solid var(--b);transition:border-color 0.15s;}
.sm-card:hover{border-color:var(--bb);}
.sm-card.tier-1{border-top:2px solid var(--rose);}
.sm-card.tier-2{border-top:2px solid var(--amber);}
.sm-card.tier-3{border-top:2px solid var(--sky);}
.sm-card.tier-4{border-top:2px solid rgba(255,255,255,0.15);}
.sm-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:6px;}
.sm-title{font-family:'Syne',sans-serif;font-weight:700;font-size:12.5px;color:#fff;line-height:1.3;}
.sm-domain{font-family:'DM Mono',monospace;font-size:7.5px;padding:2px 5px;border-radius:3px;white-space:nowrap;flex-shrink:0;}
.dom-ops{background:var(--ad);color:var(--amber);}
.dom-mkt{background:var(--vd);color:var(--vio);}
.dom-fin{background:var(--td2);color:var(--teal);}
.dom-comm{background:var(--skd);color:var(--sky);}
.dom-ai{background:var(--rd);color:var(--rose);}
.dom-trust{background:var(--grd);color:var(--green);}
.sm-body{font-size:10.5px;color:var(--tm);line-height:1.6;margin-bottom:7px;}
.sm-why{font-size:9.5px;color:var(--td);font-style:italic;line-height:1.5;padding:6px 9px;background:var(--bg3);border-radius:6px;border-left:2px solid rgba(255,255,255,0.08);}
.sm-why strong{color:var(--tm);font-style:normal;}
.arch-decisions{background:var(--bg2);border:1px solid rgba(139,92,246,0.2);border-radius:11px;padding:14px 16px;margin-top:18px;}
.arch-decisions h3{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;color:#fff;margin-bottom:10px;}
.ad-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.ad-item{background:var(--bg3);border-radius:8px;padding:10px 12px;border:1px solid var(--vd);}
.ad-q{font-family:'Syne',sans-serif;font-weight:600;font-size:11.5px;color:#fff;margin-bottom:4px;}
.ad-body{font-size:10px;color:var(--tm);line-height:1.55;}
.ad-rec{font-size:9.5px;color:var(--vio);margin-top:4px;font-family:'DM Mono',monospace;}

/* OVERLAY */
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.72);z-index:100;align-items:center;justify-content:center;}
.ov.on{display:flex;}
.oc{background:var(--bg2);border:1px solid var(--bb);border-radius:13px;padding:18px 20px;max-width:420px;width:92%;position:relative;animation:pi 0.12s ease;max-height:88vh;overflow-y:auto;}
@keyframes pi{from{opacity:0;transform:scale(0.96) translateY(4px);}to{opacity:1;transform:scale(1) translateY(0);}}
.xcl{position:absolute;top:10px;right:10px;background:var(--b);border:none;border-radius:4px;color:var(--tm);font-size:11px;width:21px;height:21px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-family:inherit;}
.xcl:hover{background:var(--bb);}
.os2{font-family:'DM Mono',monospace;font-size:8.5px;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:4px;}
.ott{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;color:#fff;margin-bottom:8px;line-height:1.2;}
.oht{font-family:'DM Mono',monospace;font-size:8px;letter-spacing:0.1em;text-transform:uppercase;color:var(--td);margin-bottom:3px;margin-top:7px;}
.ob2{font-size:11px;color:var(--tm);line-height:1.6;margin-bottom:4px;}
.ofl{list-style:none;display:flex;flex-direction:column;gap:3px;margin-bottom:6px;}
.ofl li{font-size:10px;color:var(--tm);padding-left:10px;position:relative;}
.ofl li::before{content:'→';position:absolute;left:0;color:var(--td);font-size:9px;}
.onote{background:var(--bg3);border:1px solid var(--b);border-radius:6px;padding:7px 9px;font-size:9.5px;color:var(--tm);font-style:italic;line-height:1.5;}

@media(max-width:660px){.cols,.two-col,.dom-grid,.comp-grid,.suggest-grid,.persona-bar,.ad-grid{grid-template-columns:1fr;}.mg{grid-template-columns:1fr;}h1{font-size:19px;}.tabs{flex-wrap:wrap;}}
</style>
</head>
<body>

<div class="tabs">
  <button class="tab on" onclick="sw('map')">Module Map</button>
  <button class="tab" onclick="sw('mkt')">Marketing Intelligence</button>
  <button class="tab" onclick="sw('comp')">Competitor Coverage</button>
  <button class="tab" onclick="sw('stress')">Stress Tests</button>
  <button class="tab" onclick="sw('suggest')" style="color:var(--sky);border-color:rgba(56,189,248,0.2);">Suggested Modules</button>
</div>

<!-- ══════════ TAB 1 — MODULE MAP ══════════ -->
<div class="view on" id="v-map">
<div class="hdr">
  <div class="ey">ACERIS Technologies · SLC Architecture v5.0</div>
  <h1>Solopreneur Life Co-pilot — Master Module Map</h1>
  <p class="sub">Diagnostic-configured. Agent-orchestrated. One database. <span style="color:var(--teal)">✓ sim</span> = day-one simulation fix. <span style="color:var(--vio)">↑ sync</span> = marketing sync test update. Click any module for full detail.</p>
</div>

<div class="gate-w">
  <div class="gate">
    <div class="gl">Entry point · all paths</div>
    <div class="gt">AI Readiness Diagnostic</div>
    <div class="gs">30-min session → business profile → SLC auto-configured</div>
  </div>
</div>
<div class="fork">
  <svg width="440" height="50" viewBox="0 0 440 50" style="overflow:visible">
    <line x1="220" y1="0" x2="220" y2="10" stroke="rgba(255,255,255,0.07)" stroke-width="1"/>
    <line x1="220" y1="10" x2="58" y2="10" stroke="rgba(255,255,255,0.07)" stroke-width="1"/>
    <line x1="220" y1="10" x2="382" y2="10" stroke="rgba(255,255,255,0.07)" stroke-width="1"/>
    <line x1="58" y1="10" x2="58" y2="40" stroke="rgba(29,217,160,0.2)" stroke-width="1"/>
    <line x1="382" y1="10" x2="382" y2="40" stroke="rgba(245,158,11,0.2)" stroke-width="1"/>
    <polygon points="54,38 58,46 62,38" fill="rgba(29,217,160,0.35)"/>
