function show(id){
  const m=D[id];if(!m)return;
  document.getElementById('os2').textContent=m.s;
  document.getElementById('os2').style.color=m.c;
  document.getElementById('ott').textContent=m.t;
  document.getElementById('ob2').textContent=m.b;
  document.getElementById('ofl').innerHTML=m.f.map(f=>`<li>${f}</li>`).join('');
  document.getElementById('onote').textContent=m.n;
  document.getElementById('ov').classList.add('on');
}
function co(e){if(e.target===document.getElementById('ov'))hi();}
function hi(){document.getElementById('ov').classList.remove('on');}
document.addEventListener('keydown',e=>{if(e.key==='Escape')hi();});
function sw(id){
  document.querySelectorAll('.tab').forEach((t,i)=>{
    ['map','mkt','comp','stress','suggest'].forEach((v,j)=>{
      if(i===j) t.classList.toggle('on',v===id);
    });
  });
  document.querySelectorAll('.view').forEach(v=>{
    v.classList.toggle('on',v.id==='v-'+id);
  });
}
</script>
